    A1[<strong>Pattern Definitions</strong><br/><i>61 quantum patterns</i>]
    S1[<strong>Project Library Source</strong><br/><i>Target framework .py files</i>]

%% ── Phase 1: Vocabulary Expansion ──────────────────────────────────────────
    subgraph PH1["Phase 1 — Vocabulary Expansion"]
        direction TB
        E1[<strong>7. Build Dynamic KBs</strong><br/><i>Docstring similarity vs. Seed KB<br/>threshold ≥ 0.70</i>]
        E2[<strong>Dynamic KB</strong><br/><i>data/dynamic_kb/&lt;project&gt;/<br/>per-project concept names</i>]
        E1 --> E2
    end

%% ── Phase 2: Pattern Detection ──────────────────────────────────────────────
    subgraph PH2["Phase 2 — Pattern Detection"]
        direction TB
        C1[<strong>Combined KB</strong><br/><i>Seed KB + all Dynamic KBs</i>]
        G[<strong>8. Run Analysis</strong><br/><i>7 semantic channels<br/>name · summary · title · pattern_desc<br/>defined_doc · internal_keywords · internal_comments</i>]
        V[<strong>Keyword Veto</strong><br/><i>Post-match exclusive-keyword filter</i>]
        C1 --> G
        G --> V
    end

%% ── Outputs ─────────────────────────────────────────────────────────────────
